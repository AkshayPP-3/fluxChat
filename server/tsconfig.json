{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./",
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "NodeNext",
    "target": "ES2023",
    "types": [],
    "moduleResolution": "NodeNext",
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*",
    "generated/**/*"
  ],
  "exclude": [
    "node_modules",
    "prisma.config.ts"
  ]
}
